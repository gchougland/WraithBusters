$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 480);

    #Title {
      Label #RoundEndTitle {
        Style: (...$C.@TitleStyle, HorizontalAlignment: Center);
        Padding: (Horizontal: 12);
        Text: "";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 18);

      Group {
        LayoutMode: Left;

        $C.@TextButton #PlayAgainButton {
          Text: "";
          FlexWeight: 1;
          Anchor: (Right: 8, Height: 40);
        }

        $C.@CancelTextButton #LeaveButton {
          Text: "";
          FlexWeight: 1;
          Anchor: (Height: 40);
        }
      }
    }
  }
}
